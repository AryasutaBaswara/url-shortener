{
  "id": "url-shortener-realm",
  "realm": "url-shortener-realm",
  "displayName": "URL Shortener Local Dev",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "rememberMe": true,
  "verifyEmail": false,
  "clients": [
    {
      "clientId": "url-shortener-client",
      "name": "URL Shortener Client",
      "description": "Local development client for the URL Shortener API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost/*", "http://127.0.0.1/*"],
      "webOrigins": ["+"],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "requiredActions": []
    }
  ]
}
